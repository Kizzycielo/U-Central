# Database Connection (Render PostgreSQL)
# Use the DATABASE_URL provided by Render
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OR use individual credentials for local development
DB_USER=postgres
DB_HOST=localhost
DB_NAME=ucentral
DB_PASSWORD=your_password
DB_PORT=5432

# Session Secret (generate a random string for production)
SESSION_SECRET=your_secret_key_here

# Server Port (Render automatically sets PORT, optional locally)
PORT=3000

# ⚠️  FILE STORAGE NOTE:
# ID photos are currently stored in public/uploads/ (local filesystem).
# On Render, these files will NOT persist across restarts or redeployments.
# If file persistence is needed, migrate to Cloudinary or AWS S3.
