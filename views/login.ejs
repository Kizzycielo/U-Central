<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
        <title>
            U-Central
        </title>
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body>
        <div id="authPage" class="auth-page">
            <div class="auth-card">
                <div class="auth-banner">
                    <h1>
                        U‑Central
                    </h1>
                </div>
                <div class="auth-body">
                    <form id="authForm" action="/login" method="POST">
                        <div id="dynamicFormFields">
                            <div class="input-group">
                                <input name="email" type="text" id="loginEmail" class="input-field" placeholder="Email" autocomplete="email">
                            </div>
                            <div class="input-group">
                                <input name="password" type="password" id="loginPassword" class="input-field" placeholder="Password" autocomplete="current-password">
                            </div>
                        </div>
                        <button type="submit" id="authSubmitBtn" class="btn-primary" style="display: block; width: 100%; text-align: center; border: none; cursor: pointer;">
                            Log in
                        </button>
                    </form>
                    <div class="or-divider">
                        <span>
                            OR
                        </span>
                    </div>
                    <button class="google-btn" id="googleBtn">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                        </svg>
                        Continue with Google
                    </button>
                    <div class="toggle-auth" id="toggleAuthLink">
                        No account? 
                        <a href="/signup">
                            Sign up
                        </a> 
                        &nbsp;·&nbsp; 
                        <a href="/guest" class="guest-link">
                            Continue as guest
                        </a>
                    </div>
                    <div id="authError" class="error-msg">
                    </div>
                </div>
            </div>
        </div>
        <script src="/js/app.js"></script>
    </body>
</html>